# Enable the subsequent settings only in interactive sessions
case $- in
  *i*) ;;
    *) return;;
esac

{{- if not .wsl }}
# Launch directly into tmux (psmux on Windows)
if command -v tmux &> /dev/null && \
   [[ ! "$TERM" =~ screen ]] && \
   [[ ! "$TERM" =~ tmux ]] && \
   [ -z "$TMUX" ]
then
  exec tmux new-session -As main
fi
{{- end }}

{{- if eq .chezmoi.os "android" }}
# BUG: USER isn't defined in Termux, so we define it to silence ble.sh
# https://github.com/akinomyoga/ble.sh/issues/596#issuecomment-2992320082
: "${USER:=$(id -un)}"
export USER
{{- end }}

# Forward GPG pinentry to terminal
export GPG_TTY=$(tty)

# Enable Bash Completion
{{- if eq .chezmoi.os "android" }}
BASH_COMP_PATH="/data/data/com.termux/files/usr/share/bash-completion/bash_completion"
{{- else if eq .chezmoi.os "darwin" }}
BASH_COMP_PATH="/opt/homebrew/etc/profile.d/bash_completion.sh"
{{- else }}
BASH_COMP_PATH="/usr/share/bash-completion/bash_completion"
{{- end }}
[[ -f "$BASH_COMP_PATH" ]] && . "$BASH_COMP_PATH"

# Enable ble.sh
. "$HOME/.local/share/blesh/ble.sh"

# Enable Starship
eval "$(starship init bash)"

{{- if ne .chezmoi.os "android" }}
# Enable WezTerm shell integration
. "$HOME/.config/wezterm/wezterm.sh"
{{- end }}

# Set up fzf key bindings and fuzzy completion (--bash needs fzf >= 0.48;
# skip gracefully where an older fzf ships, e.g. Ubuntu's 0.44)
if fzf --bash >/dev/null 2>&1; then
  eval "$(fzf --bash)"
fi

# Enable git-delta completion (--generate-completion needs delta >= 0.18;
# skip gracefully where an older delta ships, e.g. Ubuntu's 0.16.5)
if delta --generate-completion bash >/dev/null 2>&1; then
  eval "$(delta --generate-completion bash)"
fi

# Enable worktrunk shell integration: subprocesses can't change the parent
# shell's cwd, so `wt config shell init bash` emits a `wt` function that
# reads the directive file written by the binary and `cd`s the host shell.
command -v wt >/dev/null && eval "$(wt config shell init bash)"

# Activate mise (tool version + env + task manager); prepends real tool
# paths, overriding the shims that .profile adds for non-interactive use
command -v mise >/dev/null && eval "$(mise activate bash)"

# Add aliases
. "$HOME/.bash_aliases"

{{- if eq .chezmoi.os "android" }}

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
{{- end }}
