#!/bin/bash
# git clean wrapper that excludes patterns listed in .cleanignore.local
# Usage: git clean-safe -fdx [-n]

root="$(git rev-parse --show-toplevel)"
cleanignore="$root/.cleanignore.local"

exclude=(-e .cleanignore.local)

if [ -f "$cleanignore" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line//$'\r'/}"
        case "$line" in
            ""|\#*) continue ;;
        esac
        exclude+=(-e "$line")
    done < "$cleanignore"
fi

exec git clean "$@" "${exclude[@]}"
