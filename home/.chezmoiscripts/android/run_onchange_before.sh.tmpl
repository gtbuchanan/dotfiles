#!/data/data/com.termux/files/usr/bin/bash
# Base Termux packages. Claude Code's glibc deps (glibc-repo, glibc-runner,
# patchelf-glibc) and toolchain are owned by the claude-code-termux package,
# installed by run_onchange_after_claude-code-install.sh.tmpl.
#
# shellcheck/shfmt/ruff and clang (for clang-format) back the hk lint hooks:
# mise can't install them on android, so they come from pkg as native bionic
# builds and hk resolves them from PATH (see dot_config/mise/config.toml).
PKG_PACKAGES=(
  "bash-completion"
  "clang"
  "eza"
  "fzf"
  "git-delta"
  "gnupg"
  "jq"
  "mise"
  "ncurses-utils"
  "nodejs-lts"
  "openssh"
  "ripgrep"
  "ruff"
  "shellcheck"
  "shfmt"
  "starship"
  "termux-api"
  "termux-services"
  "tmux"
  "tudo"
  "turbo"
  "vim"
)
pkg update
pkg install -y $(printf "%s " "${PKG_PACKAGES[@]}")

# Install ble.sh
curl -L https://github.com/akinomyoga/ble.sh/releases/download/nightly/ble-nightly.tar.xz | tar -xJf - -C "$TMPDIR"
bash "$TMPDIR/ble-nightly/ble.sh" --install "$HOME/.local/share"
rm -Rf "$TMPDIR/ble-nightly"

# Install pnpm
npm i -g pnpm

# Install Nerd Font
curl -fsSL https://raw.githubusercontent.com/getnf/getnf/main/install.sh | bash
getnf -i "{{ .fontpack }}"
# Apply Mono Regular variant as Termux font
mkdir -p "$HOME/.termux"
font_dir="$HOME/.local/share/fonts/{{ .fontpack }}"
font_file=$(find "$font_dir" -name '*NerdFontMono-Regular.ttf' | head -1)
[ -z "$font_file" ] && font_file=$(find "$font_dir" -name '*Regular.ttf' | head -1)
if [ -n "$font_file" ]; then
  cp "$font_file" "$HOME/.termux/font.ttf"
  am broadcast --user 0 -a com.termux.app.reload_style com.termux > /dev/null 2>&1 || true
fi
