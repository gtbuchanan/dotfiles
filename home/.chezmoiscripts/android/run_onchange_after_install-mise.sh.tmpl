#!/data/data/com.termux/files/usr/bin/bash
{{/*
  jdx/mise install for Termux/Android.

  Not packaged in the Termux registry yet. We install from a pre-built
  .deb published at gtbuchanan/mise-termux-bin — a bridge repo that
  rebuilds mise dynamically linked against bionic, with the two patches
  from termux/termux-packages#29075.

  Going via .deb (instead of the upstream musl-static binary + a
  termux-chroot wrapper) means: shebang scripts launched by mise get
  termux-exec's LD_PRELOAD remap, DNS uses bionic's resolver, TLS uses
  Termux's libssl. No wrapper, no proot tax.

  Version pinned in `home/.chezmoidata/mise.yaml` and tracked by Renovate
  against the bridge repo's releases (so only versions we've actually
  built get proposed).
*/}}
set -euo pipefail

VERSION='{{ .mise_version }}'
RELEASE_REPO='gtbuchanan/mise-termux-bin'

# Remove the legacy musl-static install + chroot wrapper from prior runs.
rm -f "$HOME/.local/bin/mise"
rm -f "$HOME"/.local/share/mise/mise-*

if dpkg-query -W -f='${Version}\n' mise 2>/dev/null | grep -qx "$VERSION"; then
  exit 0
fi

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

gh release download "v$VERSION" \
  --repo "$RELEASE_REPO" \
  --pattern '*_aarch64.deb' \
  --output "$tmp/mise.deb"

# pkg install resolves the .deb's runtime deps (bzip2, openssl); dpkg -i
# alone would fail if any were missing.
pkg install -y "$tmp/mise.deb"
