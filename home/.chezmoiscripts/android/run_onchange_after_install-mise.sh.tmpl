#!/data/data/com.termux/files/usr/bin/bash
{{/*
  jdx/mise install for Termux/Android.

  Not packaged in the Termux registry. The musl-static release binary
  has no libc dependency and runs on Termux's bionic without patching.

  Wrapped via termux-chroot for network-touching subcommands so the
  bundled DNS resolver can reach upstream hosts. Fast paths (hook-env,
  activate, etc.) skip chroot to keep prompt overhead negligible.
  https://github.com/jdx/mise/pull/7028#issuecomment-3560656422

  Version pinned in `home/.chezmoidata/mise.yaml` and tracked by Renovate.
*/}}
set -euo pipefail

VERSION='{{ .mise_version }}'
ASSET="mise-v${VERSION}-linux-arm64-musl"
DL_BASE="https://github.com/jdx/mise/releases/download/v${VERSION}"

INSTALL_DIR="$HOME/.local/share/mise"
BINARY="$INSTALL_DIR/mise-$VERSION"
WRAPPER="$HOME/.local/bin/mise"

mkdir -p "$INSTALL_DIR" "$(dirname "$WRAPPER")"

if [ ! -x "$BINARY" ]; then
  echo "Installing mise $VERSION..."
  checksum=$(curl -fsSL "$DL_BASE/SHASUMS256.txt" \
    | awk -v a="$ASSET" '{ sub(/^\.\//, "", $2) } $2 == a { print $1 }')
  if [ -z "$checksum" ]; then
    echo "Could not find $ASSET in SHASUMS256.txt" >&2
    exit 1
  fi

  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT
  curl -fsSL "$DL_BASE/$ASSET" -o "$tmp/$ASSET"

  actual=$(sha256sum "$tmp/$ASSET" | cut -d' ' -f1)
  if [ "$actual" != "$checksum" ]; then
    echo "Checksum mismatch for $ASSET: expected $checksum, got $actual" >&2
    exit 1
  fi

  chmod +x "$tmp/$ASSET"
  mv "$tmp/$ASSET" "$BINARY"
  rm -rf "$tmp"
  trap - EXIT
fi

cat > "$WRAPPER" <<EOF
#!/data/data/com.termux/files/usr/bin/bash
# Generated by .chezmoiscripts/android/run_onchange_after_install-mise.sh.tmpl
# Chroot-by-default: mise's bundled DNS resolver can't reach upstream
# from Termux's bionic, so we route everything through termux-chroot
# except a tight whitelist of hot/local-only paths. hook-env stays at
# ~60ms; rare local commands pay ~600ms but new mise subcommands that
# might use the network are safe by default.
#
# Shim invocations (argv[0] under ~/.local/share/mise/shims/) need the
# bare path: termux-chroot's exec drops the argv[0] we set with exec -a,
# and mise's shim mode keys off basename(argv[0]) to know which tool to
# launch. Shims just exec an already-installed tool — no network.
case "\$0" in
  */shims/*)
    exec -a "\$0" '$BINARY' "\$@"
    ;;
esac
case "\${1:-}" in
  ""|-h|--help|help|activate|deactivate|hook-env|ls|list|current|where|which|bin-paths|completion)
    exec -a "\$0" '$BINARY' "\$@"
    ;;
  *)
    exec -a "\$0" termux-chroot '$BINARY' "\$@"
    ;;
esac
EOF
chmod +x "$WRAPPER"

find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 -type f -name 'mise-*' ! -name "mise-$VERSION" -delete
