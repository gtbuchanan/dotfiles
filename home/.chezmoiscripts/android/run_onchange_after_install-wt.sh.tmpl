#!/data/data/com.termux/files/usr/bin/bash
{{/*
  timvw/wt install for Termux/Android.

  Not packaged in the Termux registry. wt is a static Go binary, so the
  upstream linux-arm64 release tarball runs natively on Termux without
  any glibc patching.

  Version pinned in `home/.chezmoidata/wt.yaml` and tracked by Renovate.
*/}}
set -euo pipefail

VERSION='{{ .wt_version }}'
ARCHIVE="wt_${VERSION}_linux_arm64.tar.gz"
DL_BASE="https://github.com/timvw/wt/releases/download/v${VERSION}"

INSTALL_DIR="$HOME/.local/share/wt"
BINARY="$INSTALL_DIR/wt-$VERSION"
WRAPPER="$HOME/.local/bin/wt"

mkdir -p "$INSTALL_DIR" "$(dirname "$WRAPPER")"

if [ ! -x "$BINARY" ]; then
  echo "Installing wt $VERSION..."
  checksum=$(curl -fsSL "$DL_BASE/checksums.txt" \
    | awk -v a="$ARCHIVE" '$2 == a { print $1 }')
  if [ -z "$checksum" ]; then
    echo "Could not find $ARCHIVE in checksums.txt" >&2
    exit 1
  fi

  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT
  curl -fsSL "$DL_BASE/$ARCHIVE" -o "$tmp/$ARCHIVE"

  actual=$(sha256sum "$tmp/$ARCHIVE" | cut -d' ' -f1)
  if [ "$actual" != "$checksum" ]; then
    echo "Checksum mismatch for $ARCHIVE: expected $checksum, got $actual" >&2
    exit 1
  fi

  tar -xzf "$tmp/$ARCHIVE" -C "$tmp" wt
  chmod +x "$tmp/wt"
  mv "$tmp/wt" "$BINARY"
  rm -rf "$tmp"
  trap - EXIT
fi

ln -sf "$BINARY" "$WRAPPER"

find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 -type f -name 'wt-*' ! -name "wt-$VERSION" -delete
