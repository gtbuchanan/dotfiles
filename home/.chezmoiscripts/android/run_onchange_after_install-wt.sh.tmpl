#!/data/data/com.termux/files/usr/bin/bash
{{/*
  worktrunk install for Termux/Android.

  Not packaged in the Termux registry. Worktrunk ships musl-linked
  static binaries; aarch64-unknown-linux-musl runs natively on Termux.

  Version pinned in `home/.chezmoidata/wt.yaml` and tracked by Renovate.
*/}}
set -euo pipefail

VERSION='{{ .worktrunk_version }}'
ARCHIVE="worktrunk-aarch64-unknown-linux-musl.tar.xz"
DL_BASE="https://github.com/max-sixty/worktrunk/releases/download/v${VERSION}"

INSTALL_DIR="$HOME/.local/share/worktrunk"
BINARY="$INSTALL_DIR/wt-$VERSION"
WRAPPER="$HOME/.local/bin/wt"

mkdir -p "$INSTALL_DIR" "$(dirname "$WRAPPER")"

if [ ! -x "$BINARY" ]; then
  echo "Installing worktrunk $VERSION..."
  checksum=$(curl -fsSL "$DL_BASE/$ARCHIVE.sha256" | awk '{ print $1 }')
  if [ -z "$checksum" ]; then
    echo "Could not fetch checksum for $ARCHIVE" >&2
    exit 1
  fi

  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT
  curl -fsSL "$DL_BASE/$ARCHIVE" -o "$tmp/$ARCHIVE"

  actual=$(sha256sum "$tmp/$ARCHIVE" | cut -d' ' -f1)
  if [ "$actual" != "$checksum" ]; then
    echo "Checksum mismatch for $ARCHIVE: expected $checksum, got $actual" >&2
    exit 1
  fi

  # Archive contains worktrunk-<triple>/{wt,git-wt,README.md,LICENSE,CHANGELOG.md}.
  # On Android there's no `wt.exe` conflict, so we only need `wt`.
  tar -xJf "$tmp/$ARCHIVE" -C "$tmp" --strip-components=1 \
    "worktrunk-aarch64-unknown-linux-musl/wt"
  chmod +x "$tmp/wt"
  mv "$tmp/wt" "$BINARY"
  rm -rf "$tmp"
  trap - EXIT
fi

ln -sf "$BINARY" "$WRAPPER"

find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 -type f -name 'wt-*' ! -name "wt-$VERSION" -delete
