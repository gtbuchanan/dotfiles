{{- $root := .chezmoi.workingTree | replace "\\" "/" -}}
# pnpm-lock.yaml hash: {{ output "git" "hash-object" (joinPath $root "mcp-readonly/pnpm-lock.yaml") | trim }}
$ErrorActionPreference = 'Stop'
$McpDir = '{{ $root }}/mcp-readonly'
Set-Location $McpDir
pnpm install --frozen-lockfile --prod

$IndexMjs = "$McpDir/index.mjs"
claude mcp remove readonly --scope user 2>$null
claude mcp add --scope user readonly -- node $IndexMjs
