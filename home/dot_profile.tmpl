{{- if eq .chezmoi.os "android" }}
# Use Termux writable tmp since /tmp is owned by shell:shell (0771)
export TMPDIR="${TMPDIR:-$PREFIX/tmp}"

# oxlint-tsgolint has no android-arm64 binary; use linux-arm64 via wrapper
# https://github.com/oxc-project/tsgolint/issues/866
export OXLINT_TSGOLINT_PATH="$HOME/.local/bin/tsgolint"

# Use native Android dialogs for SSH/GPG passphrases (via termux-dialog)
export SSH_ASKPASS="$HOME/.local/bin/ssh-askpass-termux"
export SSH_ASKPASS_REQUIRE=force
{{ end -}}

# Add user's private bin to PATH
[ -d "$HOME/bin" ] && PATH="$HOME/bin:$PATH"
[ -d "$HOME/.local/bin" ] && PATH="$HOME/.local/bin:$PATH"

{{- if eq .chezmoi.os "darwin" }}
# Add Homebrew to PATH early to override built-in tool versions
PATH="/opt/homebrew/bin:$PATH"

# Add Node 20 to PATH since it's excluded by default
PATH="$(brew --prefix node@20)/bin:$PATH"
{{- end }}
