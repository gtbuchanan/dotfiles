# Sane leader key
unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

# Support readline clear screen
bind C-l send-keys 'C-l'

# Open new panes in the current directory
bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

# Status line styling
set -g status-style 'bg=#282828'
set -g status-left-length 40
# psmux: bg=default resolves to terminal bg; tmux: bg=default inherits
# from status-style, so bg=terminal is needed for visible semicircles.
# psmux also renders nerd font icons narrower, needing an extra space.
{{- if eq .chezmoi.os "windows" }}
set -g status-left '#[fg=#3A3A3A,bg=default]î‚¶#[bg=#3A3A3A,fg=white]ïƒ›  psmux #[fg=#3A3A3A,bg=cyan]î‚°#[fg=#000000] ï‰ˆ #S #[fg=cyan,bg=#282828]î‚°'
{{- else }}
set -g status-left '#[fg=#3A3A3A,bg=terminal]î‚¶#[bg=#3A3A3A,fg=white]ïƒ› tmux #[fg=#3A3A3A,bg=cyan]î‚°#[fg=#000000] ï‰ˆ #S #[fg=cyan,bg=#282828]î‚°'
{{- end }}
set -g window-status-current-format '#[fg=#282828,bg=#6F42C1]î‚°#[fg=white] #I:#W #[fg=#6F42C1,bg=#282828]î‚°'
set -g window-status-style 'fg=green'
set -g window-status-separator ''
set -g window-status-format ' #I:#W '
{{- if eq .chezmoi.os "windows" }}
set -g status-right '#[fg=#282828,bg=default]î‚´'
{{- else }}
set -g status-right '#[fg=#282828,bg=terminal]î‚´'
{{- end }}

# Define Plugins
{{- if eq .chezmoi.os "windows" }}
set -g @plugin 'psmux-plugins/ppm'
set -g @plugin 'psmux-plugins/psmux-sensible'
set -g @plugin 'psmux-plugins/psmux-resurrect'
set -g @plugin 'psmux-plugins/psmux-continuum'
set -g @continuum-restore 'on'

# Preserve user PredictionSource â€” replaces PowerShell.OnIdle workaround
# https://github.com/psmux/psmux/issues/150
set -g allow-predictions on

# Initialize PPM
run '~/.psmux/plugins/ppm/ppm.ps1'

# Override plugin commands â€” pwsh -File doesn't expand ~
# https://github.com/psmux/psmux-plugins/issues/2
bind-key C-s run-shell "pwsh -NoProfile -Command \"& '~/.psmux/plugins/psmux-resurrect/scripts/save.ps1'\""
bind-key C-r run-shell "pwsh -NoProfile -Command \"& '~/.psmux/plugins/psmux-resurrect/scripts/restore.ps1'\""
set-hook -g client-attached 'run-shell "pwsh -NoProfile -Command \"& ~/.psmux/plugins/psmux-continuum/scripts/auto_save.ps1 -IntervalMinutes 15\""'
set-hook -g after-new-session 'run-shell "pwsh -NoProfile -Command \"& ~/.psmux/plugins/psmux-continuum/scripts/auto_restore.ps1\""'

# Pane navigation (no vim detection â€” psmux lacks #{m/r:} support)
# https://github.com/marlocarlo/psmux/issues/30
bind-key -n C-h select-pane -L
bind-key -n C-j select-pane -D
bind-key -n C-k select-pane -U
bind-key -n C-l select-pane -R
bind-key -n C-\\ select-pane -l

bind-key -T copy-mode-vi C-h select-pane -L
bind-key -T copy-mode-vi C-j select-pane -D
bind-key -T copy-mode-vi C-k select-pane -U
bind-key -T copy-mode-vi C-l select-pane -R
bind-key -T copy-mode-vi C-\\ select-pane -l
{{- else }}
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'

# Initialize TPM Redux
run '~/.tmux/plugins/tpm-redux/tpm'
{{- end }}
