# Forward terminal focus events so apps consume ESC[I/ESC[O as
# control sequences instead of leaking them as literal input
set -g focus-events on

# Sane leader key
unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

# Support readline clear screen
bind C-l send-keys 'C-l'

# Open new panes in the current directory
bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

# Status line styling
set -g status-style 'bg=#282828'
set -g status-left-length 40
# psmux: bg=default resolves to terminal bg; tmux: bg=default inherits
# from status-style, so bg=terminal is needed for visible semicircles.
# psmux also renders nerd font icons narrower, needing an extra space.
{{- if eq .chezmoi.os "windows" }}
set -g status-left '#[fg=#3A3A3A,bg=default]#[bg=#3A3A3A,fg=white]  psmux #[fg=#3A3A3A,bg=cyan]#[fg=#000000]  #S #[fg=cyan,bg=#282828]'
{{- else }}
set -g status-left '#[fg=#3A3A3A,bg=terminal]#[bg=#3A3A3A,fg=white] tmux #[fg=#3A3A3A,bg=cyan]#[fg=#000000]  #S #[fg=cyan,bg=#282828]'
{{- end }}
set -g window-status-current-format '#[fg=#282828,bg=#6F42C1]#[fg=white] #I:#W #[fg=#6F42C1,bg=#282828]'
set -g window-status-style 'fg=green'
set -g window-status-separator ''
set -g window-status-format ' #I:#W '
{{- if eq .chezmoi.os "windows" }}
set -g status-right '#[fg=#282828,bg=default]'
{{- else }}
set -g status-right '#[fg=#282828,bg=terminal]'
{{- end }}

{{- if eq .chezmoi.os "windows" }}
# Disable warm panes — fresh shell every time
# https://github.com/psmux/psmux/issues/120
set -g warm off

# Preserve user PredictionSource — replaces PowerShell.OnIdle workaround
# https://github.com/psmux/psmux/issues/150
set -g allow-predictions on

# Vim-aware pane navigation via psmux-vim-navigator: C-h/j/k/l forward
# to Vim when it is the pane's foreground process and switch psmux panes
# otherwise. The Vim side forwards back at a split edge via psmux's
# bundled `tmux` shim.
# https://github.com/marlocarlo/psmux/issues/30
set -g @plugin 'psmux-plugins/psmux-vim-navigator'
{{- else }}
# Define Plugins
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'

# Initialize TPM Redux
run '~/.tmux/plugins/tpm-redux/tpm'
{{- end }}
