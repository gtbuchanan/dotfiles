#!/bin/sh
# Invoked by worktrunk's post-start hook to bring a new worktree up to a
# usable state. Worktrunk runs hooks through `sh` on every platform
# (Git Bash on Windows), so this single POSIX script covers everything.
# Add more bootstrap steps below as needed (mise install, uv sync, etc.).
#
# Args: $1=worktree_path  $2=primary_worktree_path  $3=branch

WT_PATH="$1"
WT_MAIN="$2"
WT_BRANCH="$3"

# Mirror untracked per-checkout files from $WT_MAIN, preserving subdirs:
#   *.local      .env.local, .cleanignore.local
#   *.local.*    .env.local.json, mise.local.toml
#   *.user       *.csproj.user, *.vbproj.user, *.fsproj.user
# `--directory` collapses ignored dirs (node_modules, dist, .venv, ...) into
# one entry that the regex discards cheaply (the trailing `/` fails `[^/]*$`).
git -C "$WT_MAIN" ls-files --others --exclude-standard --ignored --directory 2>/dev/null |
  grep -E '\.(local|user)(\.[^/]*)?$' |
  while IFS= read -r f; do
    dst="$WT_PATH/$f"
    mkdir -p "$(dirname "$dst")"
    cp "$WT_MAIN/$f" "$dst"
  done

# Carry over Visual Studio per-solution user state from .vs/:
#   - applicationhost.config: IIS Express bindings that .local files reference
#   - <ver>/.suo: startup project, window layout, breakpoints
# Skip the rest of .vs/ (IntelliSense caches, browse DBs) — VS regenerates.
for pattern in '.vs/*/config/applicationhost.config' '.vs/*/v*/.suo'; do
  for src in "$WT_MAIN"/$pattern; do
    [ -e "$src" ] || continue
    rel="${src#$WT_MAIN/}"
    dst="$WT_PATH/$rel"
    mkdir -p "$(dirname "$dst")"
    cp "$src" "$dst"
  done
done

# Prefer the project's mise bootstrap task when defined — it owns the
# canonical setup (pnpm install, codegen, db prep, etc.) and mise
# auto-installs its tool prerequisites. Fall back to a bare pnpm
# install for projects that haven't adopted mise tasks yet.
if mise -C "$WT_PATH" tasks info bootstrap >/dev/null 2>&1; then
  mise -C "$WT_PATH" run bootstrap
elif [ -f "$WT_PATH/pnpm-lock.yaml" ]; then
  pnpm -C "$WT_PATH" install --frozen-lockfile
fi
