#!/bin/sh
# Invoked by wt's post_remove hook to clean up branch state after the
# worktree directory is gone.
#
# Strategy:
# 1. Try `git branch -d` (safe). Succeeds for branches merged into HEAD
#    or their upstream — the traditional-merge / rebase-merge case.
# 2. If `-d` refuses, check whether the upstream is `[gone]`. With
#    fetch.prune (or `delete-branch on merge` in the PR), a squash- or
#    rebase-merged branch's remote counterpart is deleted, leaving the
#    local branch with a tombstoned upstream. That's a strong signal the
#    work landed even though git's patch check can't see it.
# 3. Otherwise the branch has commits not yet on the default branch
#    AND no signal it was merged remotely. Print git's refusal and exit
#    clean — wt's "post_remove hook failed" warning would be noisier
#    than git's own message, and the user can decide whether to nuke it.

set -u

if git -C "$WT_MAIN" branch -d "$WT_BRANCH" 2>/dev/null; then
  exit 0
fi

upstream_track=$(git -C "$WT_MAIN" for-each-ref \
  --format='%(upstream:track)' "refs/heads/$WT_BRANCH" 2>/dev/null || true)
if [ "$upstream_track" = "[gone]" ]; then
  git -C "$WT_MAIN" branch -D "$WT_BRANCH"
  exit 0
fi

git -C "$WT_MAIN" branch -d "$WT_BRANCH" || true
exit 0
