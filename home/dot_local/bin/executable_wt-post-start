#!/bin/sh
# worktrunk post-start hook: slow, background project setup for a fresh
# worktree. Runs after creation returns, once wt-pre-start has mirrored the
# per-checkout files and trusted the worktree's mise config.
#
# Args: $1=worktree_path

WT_PATH="$1"

if mise -C "$WT_PATH" tasks info prepare >/dev/null 2>&1; then
  # Run project-level per-worktree preparation, when available
  mise -C "$WT_PATH" run prepare
elif mise -C "$WT_PATH" tasks info bootstrap >/dev/null 2>&1; then
  # TODO: mise now has a built-in `bootstrap` command with different semantics, so this is
  # deprecated in favor of `prepare` task above. Remove it after projects have migrated
  mise -C "$WT_PATH" run bootstrap
elif [ -f "$WT_PATH/pnpm-lock.yaml" ]; then
  # Fallback to pnpm on non-mise projects
  pnpm -C "$WT_PATH" install --frozen-lockfile
elif [ -f "$WT_PATH/package-lock.json" ]; then
  # Fallback to npm on non-pnpm projects
  npm --prefix "$WT_PATH" ci
fi
