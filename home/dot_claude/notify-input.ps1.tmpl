$icon = '{{ .chezmoi.workingTree }}/assets/claude.png'

$label = $null
try {
  $paneMap = @{}
  psmux list-panes -a -F '#{pane_pid}|#S:#W.#P' | ForEach-Object {
    $parts = $_ -split '\|', 2
    $paneMap[[int]$parts[0]] = $parts[1]
  }
  $procMap = @{}
  Get-CimInstance Win32_Process -Property ProcessId,ParentProcessId | ForEach-Object {
    $procMap[[int]$_.ProcessId] = [int]$_.ParentProcessId
  }
  $current = $PID
  while ($current -gt 0) {
    if ($paneMap.ContainsKey($current)) {
      $label = $paneMap[$current]
      break
    }
    if (-not $procMap.ContainsKey($current)) { break }
    $current = $procMap[$current]
  }
} catch {}
if (-not $label) { $label = 'Claude' }

$params = @{
  Text = 'Claude Code',"$label needs input"
  AppLogo = $icon
}
if ($label -ne 'Claude') {
  $url = "claude-pane://focus?target=$([Uri]::EscapeDataString($label))"
  $params['Button'] = New-BTButton -Content 'Focus' -Arguments $url -ActivationType Protocol
}
New-BurntToastNotification @params
