{{- /*
  Only auto-allow MCP readonly tools here. Built-in tools (Read, Glob,
  Grep, Agent) are intentionally excluded: they have no path restrictions,
  so auto-allowing them would widen the blast radius of prompt injection.
*/ -}}
{
  "autoMemoryEnabled": false,
{{- if eq .chezmoi.os "windows" }}
  "defaultShell": "powershell",
{{- end }}
  "effortLevel": "high",
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true,
    "powershell-editor-services@claude-code-lsps": true,
    {{/* disabled: routes .js/.mjs to eslint instead of vtsls — https://github.com/anthropics/claude-code/issues/32912 */}}
    "vscode-langservers@claude-code-lsps": false,
    "vtsls@claude-code-lsps": true,
    "vue-volar@claude-code-lsps": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "mcp__microsoft-learn__microsoft_code_sample_search",
      "mcp__microsoft-learn__microsoft_docs_fetch",
      "mcp__microsoft-learn__microsoft_docs_search",
      "mcp__readonly__acli",
      "mcp__readonly__az",
      "mcp__readonly__chezmoi",
      "mcp__readonly__gh",
      "mcp__readonly__git",
      "mcp__readonly__npm",
      "mcp__readonly__pnpm",
      "mcp__readonly__shell"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "command": "~/.claude/statusline",
    "padding": 0,
    "type": "command"
  },
  "teammateMode": "tmux",
  "viMode": true
}
