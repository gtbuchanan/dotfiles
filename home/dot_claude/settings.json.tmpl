{{- /*
  Only auto-allow MCP readonly tools here. Built-in tools (Read, Glob,
  Grep, Agent) are intentionally excluded: they have no path restrictions,
  so auto-allowing them would widen the blast radius of prompt injection.
*/ -}}
{
  "autoMemoryEnabled": false,
{{- /* Android: binary is managed by the claude-code-termux package; block the in-session updater from clobbering the ELF-patched binary. */ -}}
{{- if eq .chezmoi.os "android" }}
  "autoUpdates": false,
{{- end }}
{{- if eq .chezmoi.os "windows" }}
  "defaultShell": "powershell",
{{- end }}
  "effortLevel": "high",
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true,
    "powershell-editor-services@claude-code-lsps": true,
    {{/* disabled: routes .js/.mjs to eslint instead of vtsls — https://github.com/anthropics/claude-code/issues/32912 */}}
    "vscode-langservers@claude-code-lsps": false,
    "vtsls@claude-code-lsps": true,
    "vue-volar@claude-code-lsps": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"{{- if eq .chezmoi.os "android" }},
{{- /*
  Android: re-arm termux-exec for subprocesses so /usr/bin/env shebangs
  resolve (pnpm, etc.). Claude's own process can't have this preloaded —
  libtermux-exec-ld-preload.so has DT_NEEDED for unversioned `libc.so`,
  which crashes glibc binaries on startup — but by the time this env is
  applied the dynamic linker is already done with claude; it only takes
  effect in subprocesses, which is exactly what we want. Claude's
  launcher wrapper clears LD_PRELOAD before exec'ing the binary so this
  value doesn't leak into the binary's own startup.

  This LD_PRELOAD also leaks into claude's shell snapshot subprocesses,
  whose `grep`/`find`/`rg` functions re-exec the claude binary via
  $CLAUDE_CODE_EXECPATH. That re-exec inherits LD_PRELOAD and crashes
  with "libc.so: invalid ELF header" (libtermux-exec can't load into
  glibc — bionic ABI). The claude-code-termux package patches the binary
  so it sets CLAUDE_CODE_EXECPATH="" in subprocess env; the snapshot's
  `[[ -x $_cc_bin ]] || _cc_bin=$WRAPPER` fallback then routes the
  re-exec through the wrapper, which clears LD_PRELOAD.
*/}}
    "LD_PRELOAD": "/data/data/com.termux/files/usr/lib/libtermux-exec-ld-preload.so"
{{- end }}
  },
{{- if eq .chezmoi.os "windows" }}
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "async": true,
            "command": "& $HOME/.claude/notify-input.ps1",
            "shell": "powershell",
            "type": "command"
          }
        ]
      }
    ]
  },
{{- end }}
  "permissions": {
    "allow": [
      "mcp__microsoft-learn__microsoft_code_sample_search",
      "mcp__microsoft-learn__microsoft_docs_fetch",
      "mcp__microsoft-learn__microsoft_docs_search",
      "mcp__readonly__acli",
      "mcp__readonly__az",
      "mcp__readonly__chezmoi",
      "mcp__readonly__gh",
      "mcp__readonly__git",
      "mcp__readonly__npm",
      "mcp__readonly__pnpm",
      "mcp__readonly__shell"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
{{- /* Android: invoke via bash explicitly so kernel never resolves the /usr/bin/env shebang (no termux-exec preload in glibc claude). */ -}}
{{- if eq .chezmoi.os "android" }}
    "command": "bash ~/.claude/statusline",
{{- else }}
    "command": "~/.claude/statusline",
{{- end }}
    "padding": 0,
    "type": "command"
  },
  "teammateMode": "tmux",
  "viMode": true
}
