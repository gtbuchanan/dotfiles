---
{{- /* lintSkipExternals is set true only by scripts/lint-templates.sh (via
   --override-data) to render this file empty, so `chezmoi ignored` need not
   realize these externals — downloading archives, SSH-cloning repos — merely to
   compute the template ignore set. `get` reads it without erroring when unset
   (chezmoi runs templates with missingkey=error). Normal apply never sets it. */ -}}
{{- if not (get . "lintSkipExternals") }}
{{- if eq .hosttype "ewn" }}
'.agents/skills/atlassian-cli':
  exact: true
  type: archive
  stripComponents: 2
  include: ["*/skill/**"]
  url: https://github.com/peetzweg/acli-skill/archive/5e93e0a38f6fe210329cb1fafd06b1637db6aa0d.tar.gz

{{- $msSkills := list "azure-devops" "azure-pipelines" }}
{{- range $msSkills }}
'.agents/skills/{{ . }}':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/{{ . }}/**"]
  url: https://github.com/MicrosoftDocs/agent-skills/archive/aab6d7889eadd5e90ff685c486a8ca1ee24c0f5f.tar.gz
{{ end -}}
{{- end }}

'.agents/skills/cloudflare':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/cloudflare/**"]
  url: https://github.com/cloudflare/skills/archive/60147cbb773649eadca89cee92b4e0caf02234b4.tar.gz

'.agents/skills/mise-guide':
  exact: true
  type: archive
  stripComponents: 2
  include: ["*/mise-guide/**"]
  url: https://github.com/kinoward/agent-skills/archive/98fd4ad7e39d7eba170ed1ef4787e16bc88cef05.tar.gz

'.agents/skills/playwright-cli':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/playwright-cli/**"]
  url: https://github.com/microsoft/playwright-cli/archive/refs/tags/v0.1.17.tar.gz

'.agents/skills/skill-creator':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/skill-creator/**"]
  url: https://github.com/anthropics/skills/archive/da20c92503b2e8ff1cf28ca81a0df4673debdbf7.tar.gz

'.agents/skills/turborepo':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/turborepo/**"]
  url: https://github.com/vercel/turborepo/archive/8b86297dcdfa4508b5b44788a38a35d5d933329a.tar.gz

'.agents/skills/worktrunk':
  exact: true
  type: archive
  stripComponents: 3
  include: ["*/skills/worktrunk/**"]
  url: https://github.com/max-sixty/worktrunk/archive/refs/tags/v{{ .worktrunk_version }}.tar.gz

{{- if ne .chezmoi.os "windows" }}
# https://wezterm.org/shell-integration.html
'.config/wezterm/wezterm.sh':
  refreshPeriod: 128h
  type: file
  url: https://raw.githubusercontent.com/wezterm/wezterm/refs/heads/main/assets/shell-integration/wezterm.sh
{{- end }}

{{- if eq .chezmoi.os "windows" }}
'Documents/PowerShell/Modules/PowerShellEditorServices':
  exact: true
  type: archive
  stripComponents: 1
  include: ["PowerShellEditorServices/**"]
  url: https://github.com/PowerShell/PowerShellEditorServices/releases/latest/download/PowerShellEditorServices.zip

{{- else }}
'.tmux/plugins/tpm-redux':
  exact: true
  stripComponents: 1
  type: archive
  url: https://github.com/RyanMacG/tpm-redux/archive/refs/tags/v1.2.0.tar.gz
{{- end }}

'.vim/autoload/plug.vim':
  refreshPeriod: 168h
  type: file
  url: https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim

# Git repos this dotfiles repo references but doesn't vendor, cloned under
# ~/{{ .codeDir }}. Cloned on first apply, refreshed weekly so chezmoi doesn't
# pull over local work. Keyed on .codeDir so the casing tracks each platform.
{{- $refresh := "168h" }}
# Personal skills — all trusted, since I author the repo. Cloned whole (not
# enumerated per-skill) so every skill is installed and new ones are picked up
# automatically without publishing the skill names here; a per-OS run_after
# script then symlinks each skills/* into .agents/skills/<name>. This
# clone-then-symlink indirection is required because chezmoi's git-repo
# externals can't stripComponents/flatten like archive externals, and archive
# externals can't authenticate over SSH (needed for this private repo).
'{{ .codeDir }}/skills':
  refreshPeriod: {{ $refresh }}
  type: git-repo
  url: git@github.com:gtbuchanan/skills.git
{{- if and (eq .hosttype "ewn") (eq .chezmoi.os "windows") }}
# Imported by the PowerShell profile.
'{{ .codeDir }}/PSRSA':
  refreshPeriod: {{ $refresh }}
  type: git-repo
  url: git@github.com:energyworldnet/PSRSA.git
{{- end }}
{{- if eq .chezmoi.os "windows" }}
# Backs the `git amt` alias.
'{{ .codeDir }}/git-add-mergetool':
  refreshPeriod: {{ $refresh }}
  type: git-repo
  url: git@gist.github.com:3c5e44100c5a83f4aec7d2a832d50d42.git
{{- end }}
{{- if eq .hosttype "ewn" }}
# Backs the `git unpicked` alias.
'{{ .codeDir }}/git-unpicked':
  refreshPeriod: {{ $refresh }}
  type: git-repo
  url: git@gist.github.com:1a9699e8350d2eacc73de902c29d8ea0.git
{{- end }}
{{- end }}
