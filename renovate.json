{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>gtbuchanan/tooling"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^home/\\.chezmoidata/.+\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s*\\n[ \\t]*\\S+:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ]
    }
  ]
}
