/// Pre-commit config for developing this chezmoi repo. Adopts the shared
/// @gtbuchanan/hk-config `recommended` preset and adds a guard that mise's
/// generated tasks stay in sync. Tool versions come from mise.toml.
amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

import "package://github.com/gtbuchanan/tooling/releases/download/hk-config@0.2.1/hk-config@0.2.1#/Defaults.pkl"

// chezmoi source templates embed Go template syntax ({{ ... }}) that shfmt and
// shellcheck can't parse as shell, so drop .tmpl from the shell steps (hk types
// them as shell via their shebang). Plain scripts stay covered; linting the
// rendered output is deferred to a future render-first step.
local shellExclude: Regex = Regex("\(Defaults.defaultExclude.pattern)|\\.tmpl$")

// Spread the preset into a base mapping, then amend. Overriding a spread-in
// member in the same object body is a duplicate-definition error under stricter
// Pkl builds (e.g. the system Pkl used on Android, where hk has no bundled
// binary); amending in a separate layer overrides cleanly on every Pkl version.
local baseSteps = new Mapping<String, Step> {
  ...Defaults.recommended
}

local allSteps = (baseSteps) {
  ["shellcheck"] = (Defaults.shellcheck) { exclude = shellExclude }
  ["shfmt"] = (Defaults.shfmt) { exclude = shellExclude }

  ["eslint"] {
    check = "pnpm exec eslint --max-warnings=0 --no-warn-ignored {{files}}"
    fix = "pnpm exec eslint --fix --max-warnings=0 --no-warn-ignored {{files}}"
  }

  // `gtb sync mise` generates mise.tasks.toml; guard the loader include and
  // generated content against drift.
  ["verify-mise"] {
    glob = List("mise.toml", "mise.tasks.toml")
    check = "gtb verify mise"
  }

  // Delegates to the test:templates mise task (the single render entrypoint the
  // CI legs also call) rather than invoking lint-templates.sh directly, so the
  // hook and CI render through one definition. The task self-selects via
  // `chezmoi ignored`, checking only this OS's templates.
  ["render-templates"] {
    glob = List("**/*.tmpl")
    check = "mise run test:templates -- {{files}}"
  }

  // PSScriptAnalyzer over PowerShell sources. The `**/*.ps1` glob leaves
  // `.ps1.tmpl` to render-templates (rendered-output linting is deferred with
  // the shell case). pwsh is aqua-managed via mise; the module is provisioned
  // into .psmodules by scripts/provision-psmodules.ps1 (mise postinstall).
  // Check-only: PSScriptAnalyzer's -Fix is unreliable (see lint-powershell.ps1),
  // so no fix command is wired; formatting is left to the editor.
  ["psscriptanalyzer"] {
    glob = List("**/*.ps1")
    exclude = Defaults.defaultExclude
    check = "pwsh -NoProfile -File scripts/lint-powershell.ps1 {{files}}"
  }
}

hooks = Defaults.hooksFor(allSteps)
